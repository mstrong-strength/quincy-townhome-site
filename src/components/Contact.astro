---
import { property } from '../data/property';
---
<section id="contact" class="scroll-mt-20 bg-ink text-white">
  <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- CTA column -->
      <div class="reveal">
        <span class="inline-flex items-center gap-2 rounded-full bg-brand px-3 py-1 text-xs font-bold uppercase tracking-wide text-ink">{property.offer}</span>
        <h2 class="mt-4 font-display text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">Ready to make it yours?</h2>
        <p class="mt-4 max-w-md text-lg text-white/75">Apply online, book a tour, or take the 3D walkthrough. Brand-new homes, two months free.</p>

        <div class="mt-8 flex flex-col gap-3 sm:max-w-sm">
          <a href={property.links.apply} target="_blank" rel="noopener"
            class="rounded-full bg-brand px-6 py-3.5 text-center text-base font-semibold text-ink transition-transform hover:scale-[1.02]">Apply Now</a>
          <a href={property.phoneHref}
            class="rounded-full border border-white/30 bg-white/5 px-6 py-3.5 text-center text-base font-semibold text-white transition-colors hover:bg-white hover:text-ink">Call or Text to Tour</a>
          <a href={property.links.matterport} target="_blank" rel="noopener"
            class="rounded-full border border-white/30 bg-white/5 px-6 py-3.5 text-center text-base font-semibold text-white transition-colors hover:bg-white hover:text-ink">View 3D Tour</a>
        </div>

        <div class="mt-10 rounded-2xl border border-brand/40 bg-brand/10 p-6">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand">Schedule a showing</p>
          <p class="mt-1 text-white/80">Call or text to set up a tour:</p>
          <a href={property.phoneHref} class="mt-1 inline-block text-3xl font-bold text-brand hover:underline">{property.phone}</a>
        </div>
      </div>

      <!-- Inquiry form -->
      <div class="reveal rounded-2xl bg-white p-7 text-ink shadow-xl sm:p-8">
        <h3 class="text-lg font-semibold">Request more info</h3>
        <p class="mt-1 text-sm text-ink-soft">Have a question? Send us a note and we'll be in touch.</p>

        <form name="inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks/" class="mt-6 space-y-4">
          <input type="hidden" name="form-name" value="inquiry" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm font-medium">Name
              <input type="text" name="name" required class="mt-1 w-full rounded-lg border border-line px-3 py-2.5 text-ink focus:border-brand focus:outline-none" />
            </label>
            <label class="block text-sm font-medium">Phone
              <input type="tel" name="phone" class="mt-1 w-full rounded-lg border border-line px-3 py-2.5 text-ink focus:border-brand focus:outline-none" />
            </label>
          </div>
          <label class="block text-sm font-medium">Email
            <input type="email" name="email" required class="mt-1 w-full rounded-lg border border-line px-3 py-2.5 text-ink focus:border-brand focus:outline-none" />
          </label>
          <label class="block text-sm font-medium">Desired move-in date
            <input type="date" name="move_in" class="mt-1 w-full rounded-lg border border-line px-3 py-2.5 text-ink focus:border-brand focus:outline-none" />
          </label>
          <label class="block text-sm font-medium">Message
            <textarea name="message" rows="3" class="mt-1 w-full rounded-lg border border-line px-3 py-2.5 text-ink focus:border-brand focus:outline-none"></textarea>
          </label>
          <button type="submit" class="w-full rounded-full bg-ink px-6 py-3 text-base font-semibold text-white transition-opacity hover:opacity-90">Send inquiry</button>
        </form>
      </div>
    </div>
  </div>
</section>
