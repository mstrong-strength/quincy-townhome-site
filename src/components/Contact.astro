---
import { property } from '../data/property';
---
<section id="contact" class="scroll-mt-20 bg-ink text-white">
  <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
    <div class="grid items-stretch gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- CTA column -->
      <div class="reveal">
        <h2 class="font-display text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">Ready to make it yours?</h2>
        <p class="mt-4 max-w-md text-lg text-white/75">Apply online, tour the home, or take the 3D walkthrough. Brand-new homes in Millcreek.</p>

        <div class="mt-8 flex flex-col gap-3 sm:max-w-sm">
          <a href={property.links.apply} target="_blank" rel="noopener"
            class="rounded-full bg-brand px-6 py-3.5 text-center text-base font-semibold text-ink transition-transform hover:scale-[1.02]">Apply Now</a>
          <a href={property.phoneHref}
            class="rounded-full border border-white/30 bg-white/5 px-6 py-3.5 text-center text-base font-semibold text-white transition-colors hover:bg-white hover:text-ink">Call or Text to Tour</a>
          <a href={property.links.matterport} target="_blank" rel="noopener"
            class="rounded-full border border-white/30 bg-white/5 px-6 py-3.5 text-center text-base font-semibold text-white transition-colors hover:bg-white hover:text-ink">View 3D Tour</a>
        </div>
      </div>

      <!-- Call / text us -->
      <div class="reveal flex flex-col justify-center rounded-2xl border border-brand/40 bg-brand/10 p-8 text-center sm:p-10">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">Showings · Questions · More info</p>
        <h3 class="mt-3 font-display text-2xl font-semibold sm:text-3xl">Call or text us</h3>
        <p class="mt-3 text-white/75">To schedule a showing, ask a question, or get more info — just call or text. We're happy to help.</p>
        <a href={property.phoneHref} class="mt-5 inline-block text-4xl font-bold text-brand hover:underline">{property.phone}</a>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center">
          <a href={property.phoneHref} class="rounded-full bg-brand px-8 py-3 text-base font-semibold text-ink transition-transform hover:scale-[1.03]">Call</a>
          <a href={property.smsHref} class="rounded-full border border-white/30 bg-white/5 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-white hover:text-ink">Text</a>
        </div>
      </div>
    </div>
  </div>
</section>
