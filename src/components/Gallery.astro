---
import { Image, getImage } from 'astro:assets';
import exterior from '../assets/photos/02-exterior-facade.jpg';
import kOpen from '../assets/photos/03-kitchen-living-open.jpg';
import kIsland from '../assets/photos/04-kitchen-island.jpg';
import kPendants from '../assets/photos/05-kitchen-pendants.jpg';
import living from '../assets/photos/06-living-balcony.jpg';
import bed1 from '../assets/photos/07-bedroom-window.jpg';
import bed2 from '../assets/photos/08-bedroom-dual-window.jpg';
import bathShower from '../assets/photos/09-bathroom-shower.jpg';
import stair from '../assets/photos/10-stairwell-window.jpg';
import closet from '../assets/photos/11-walk-in-closet.jpg';
import bathTub from '../assets/photos/12-bathroom-tub.jpg';
import laundry from '../assets/photos/13-laundry-hookup.jpg';

const groups = [
  {
    title: 'Exterior',
    items: [
      { src: exterior, alt: 'Modern three-story townhome facade with black-and-white siding and an attached two-car garage under a clear sky' },
    ],
  },
  {
    title: 'Living & Kitchen',
    items: [
      { src: kOpen, alt: "Open-concept main floor where the chef's kitchen flows into a bright living area with light wood floors" },
      { src: kIsland, alt: 'Kitchen with a white quartz waterfall island, stainless steel appliances, and dark wood cabinetry' },
      { src: kPendants, alt: 'Close-up of the kitchen island and three black Edison-bulb pendant lights above the quartz countertop' },
      { src: living, alt: 'Living room with light wood flooring and a sliding glass door to a private balcony' },
    ],
  },
  {
    title: 'Bedrooms',
    items: [
      { src: bed1, alt: 'Carpeted bedroom with a large window and abundant natural light' },
      { src: bed2, alt: 'Corner bedroom with two windows, neutral walls, and plush carpet' },
    ],
  },
  {
    title: 'Bathrooms',
    items: [
      { src: bathShower, alt: 'Modern bathroom with a glass walk-in shower, hexagon tile, matte-black fixtures, and a quartz vanity' },
      { src: bathTub, alt: 'Full bathroom with a soaking tub and shower combination, matte-black fixtures, and a quartz-topped vanity' },
    ],
  },
  {
    title: 'Features & Views',
    items: [
      { src: closet, alt: 'Walk-in closet with built-in white shelving and a hanging rod' },
      { src: laundry, alt: 'In-unit laundry nook with washer and dryer hookups over wood-look flooring' },
      { src: stair, alt: 'Carpeted stairwell lit by a tall window showing the Millcreek foothills in the distance' },
    ],
  },
];

// Pre-generate larger images for the lightbox.
const allItems = groups.flatMap((g) => g.items);
const fulls = await Promise.all(allItems.map((it) => getImage({ src: it.src, width: 1800, format: 'webp' })));
const fullMap = new Map(allItems.map((it, i) => [it.src, fulls[i].src]));
let idx = -1;
---
<section id="photos" class="scroll-mt-20 bg-paper">
  <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-24">
    <header class="reveal mb-12 max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-dark">Gallery</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Take a look inside</h2>
      <p class="mt-3 text-ink-soft">A walk through the home, room by room. Tap any photo to enlarge.</p>
    </header>

    {groups.map((group) => (
      <div class="mb-12 last:mb-0">
        <h3 class="reveal mb-4 text-sm font-semibold uppercase tracking-wider text-ink-soft">{group.title}</h3>
        <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-3">
          {group.items.map((it) => {
            idx++;
            const i = idx;
            return (
              <button
                type="button"
                class="reveal group relative block aspect-[4/3] overflow-hidden rounded-xl bg-sand"
                data-lightbox={i}
                data-full={fullMap.get(it.src)}
                data-alt={it.alt}
                aria-label={`Enlarge photo: ${it.alt}`}
              >
                <Image
                  src={it.src}
                  alt={it.alt}
                  widths={[320, 480, 768]}
                  sizes="(min-width:1024px) 30vw, 45vw"
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <span class="pointer-events-none absolute inset-0 bg-ink/0 transition-colors group-hover:bg-ink/10"></span>
              </button>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/92 p-4 sm:p-8" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button id="lbClose" class="absolute right-4 top-4 rounded-full bg-white/10 p-2.5 text-white transition-colors hover:bg-white/25" aria-label="Close (Esc)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button id="lbPrev" class="absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-2.5 text-white transition-colors hover:bg-white/25 sm:left-6" aria-label="Previous photo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button id="lbNext" class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-2.5 text-white transition-colors hover:bg-white/25 sm:right-6" aria-label="Next photo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <figure class="flex max-h-full max-w-5xl flex-col items-center">
      <img id="lbImg" src="" alt="" class="max-h-[80vh] w-auto rounded-lg object-contain" />
      <figcaption id="lbCaption" class="mt-3 max-w-2xl text-center text-sm text-white/80"></figcaption>
    </figure>
  </div>
</section>

<script is:inline>
  (function () {
    var triggers = Array.prototype.slice.call(document.querySelectorAll('[data-lightbox]'));
    var lb = document.getElementById('lightbox');
    var img = document.getElementById('lbImg');
    var cap = document.getElementById('lbCaption');
    if (!triggers.length || !lb || !img || !cap) return;
    var items = triggers.map(function (t) { return { full: t.getAttribute('data-full'), alt: t.getAttribute('data-alt') }; });
    var current = 0;
    var lastFocus = null;

    function show(i) {
      current = (i + items.length) % items.length;
      img.src = items[current].full;
      img.alt = items[current].alt;
      cap.textContent = items[current].alt;
    }
    function open(i) {
      lastFocus = document.activeElement;
      show(i);
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
      document.getElementById('lbClose').focus();
    }
    function close() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
      if (lastFocus) lastFocus.focus();
    }
    triggers.forEach(function (t, i) { t.addEventListener('click', function () { open(i); }); });
    document.getElementById('lbClose').addEventListener('click', close);
    document.getElementById('lbPrev').addEventListener('click', function () { show(current - 1); });
    document.getElementById('lbNext').addEventListener('click', function () { show(current + 1); });
    lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
    document.addEventListener('keydown', function (e) {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(current - 1);
      else if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>
