---
import { property } from '../data/property';
const mapEmbed =
  'https://www.google.com/maps?q=4372+S+900+E,+Millcreek,+UT+84124&output=embed';
---
<section id="neighborhood" class="scroll-mt-20 bg-sand">
  <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-24">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div class="reveal">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-dark">Neighborhood</p>
        <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Millcreek, close to everything</h2>
        <ul class="mt-6 space-y-3">
          {property.neighborhood.map((n) => (
            <li class="flex items-start gap-3 text-ink-soft">
              <svg class="mt-1 shrink-0 text-brand-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-6.2-7-11a7 7 0 0 1 14 0c0 4.8-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
              {n}
            </li>
          ))}
        </ul>
        <a href={property.links.maps} target="_blank" rel="noopener"
          class="mt-6 inline-block text-sm font-semibold text-brand-dark hover:underline">Open in Google Maps →</a>
      </div>

      <div class="reveal overflow-hidden rounded-2xl border border-line bg-white shadow-sm">
        <iframe
          src={mapEmbed}
          title="Map of 4372 S 900 E, Millcreek, UT 84124"
          class="aspect-[4/3] w-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
