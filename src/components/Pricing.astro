---
import { property } from '../data/property';
const { moveInFees, securityDeposit, dueAtMoveIn } = property;
---
<section id="pricing" class="scroll-mt-20 bg-paper">
  <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-24">
    <header class="reveal mb-12 max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-dark">Transparent pricing</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">What you'll pay</h2>
      <p class="mt-3 text-ink-soft">No surprises. Here's exactly what's covered and what's yours.</p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Owner covers -->
      <div class="reveal rounded-2xl border border-line bg-sand p-7">
        <h3 class="flex items-center gap-2 text-lg font-semibold text-ink">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-brand-dark" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
          Owner covers
        </h3>
        <ul class="mt-5 space-y-3">
          {property.ownerPays.map((item) => (
            <li class="flex items-center gap-3 text-ink-soft">
              <svg class="shrink-0 text-brand-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Tenant covers -->
      <div class="reveal rounded-2xl border border-line bg-white p-7 shadow-sm">
        <h3 class="text-lg font-semibold text-ink">You cover (monthly)</h3>
        <ul class="mt-5 divide-y divide-line">
          {property.tenantPays.map((item) => (
            <li class="flex items-baseline justify-between gap-4 py-2.5">
              <span class="text-ink-soft">
                {item.label}
                {item.note && <span class="block text-xs text-ink-soft/70">{item.note}</span>}
              </span>
              <span class="shrink-0 font-semibold text-ink">{item.amount ?? '—'}</span>
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-ink-soft/70">Plus renter's insurance. The Resident Benefits Package may be adjusted at onboarding.</p>
      </div>
    </div>

    <!-- Move-in + offer -->
    <div class="reveal mt-6 grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-line bg-white p-7 shadow-sm">
        <h3 class="text-lg font-semibold text-ink">Move-in costs</h3>
        <ul class="mt-5 space-y-2.5">
          <li class="flex justify-between text-ink-soft"><span>Non-refundable cleaning fee</span><span class="font-semibold text-ink">${moveInFees.cleaning}</span></li>
          <li class="flex justify-between text-ink-soft"><span>Lease initiation fee</span><span class="font-semibold text-ink">${moveInFees.leaseInit}</span></li>
          <li class="flex justify-between text-ink-soft"><span>Security deposit <span class="text-xs text-ink-soft/70">(refundable)</span></span><span class="font-semibold text-ink">${securityDeposit.toLocaleString()}</span></li>
          <li class="mt-2 flex justify-between border-t border-line pt-3 text-ink"><span class="font-semibold">Due at move-in</span><span class="font-bold">${dueAtMoveIn.toLocaleString()}</span></li>
        </ul>
        <p class="mt-3 text-xs text-ink-soft/70">${moveInFees.total} in one-time fees + a refundable ${securityDeposit.toLocaleString()} deposit.</p>
      </div>

      <div class="flex flex-col justify-center rounded-2xl bg-ink p-7 text-white">
        <p class="font-display text-2xl font-semibold leading-snug">Tour it today. Move in tomorrow.</p>
        <p class="mt-2 text-white/70">Move in for ${moveInFees.total} in one-time fees plus a refundable ${securityDeposit.toLocaleString()} deposit. Call or text <a href={property.phoneHref} class="font-semibold text-brand hover:underline">{property.phone}</a> to set up a showing.</p>
      </div>
    </div>
  </div>
</section>
