---
// Renders a visible amber placeholder so unconfirmed facts never ship silently.
// Usage: <Tbd label="bath count" />
interface Props {
  label: string;
}
const { label } = Astro.props;
---
<span
  class="inline-flex items-center gap-1 rounded border border-amber-400 bg-amber-50 px-1.5 py-0.5 align-middle text-xs font-semibold text-amber-700"
  title="Placeholder — confirm this value before go-live"
  data-tbd
>
  <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2 1 21h22L12 2zm0 6 6.5 11h-13L12 8zm-1 4v3h2v-3h-2zm0 4v2h2v-2h-2z"/></svg>
  {label}
</span>
