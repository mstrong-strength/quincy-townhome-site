---
import { property } from '../data/property';
---
<section id="tour" class="scroll-mt-20 bg-ink">
  <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-24">
    <header class="reveal mb-8 max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand">3D Tour</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl">Walk through the home in 3D</h2>
      <p class="mt-3 text-white/70">Explore every room at your own pace before you ever schedule a visit.</p>
    </header>

    <div
      id="tourFrame"
      data-src={property.links.matterport}
      class="reveal relative aspect-[3/4] w-full overflow-hidden rounded-2xl bg-ink-soft/40 sm:aspect-video"
    >
      <noscript>
        <iframe
          src={property.links.matterport}
          title="Matterport 3D walkthrough of the Quincy townhome"
          class="absolute inset-0 h-full w-full"
          allow="xr-spatial-tracking; fullscreen"
          allowfullscreen
        ></iframe>
      </noscript>
      <button
        type="button"
        id="tourLoad"
        class="absolute inset-0 flex flex-col items-center justify-center gap-3 text-white transition-colors hover:bg-white/5"
        aria-label="Load the interactive 3D tour"
      >
        <span class="flex h-16 w-16 items-center justify-center rounded-full bg-brand text-ink shadow-lg">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        </span>
        <span class="text-sm font-semibold">Launch 3D walkthrough</span>
      </button>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var wrap = document.getElementById('tourFrame');
    var btn = document.getElementById('tourLoad');
    if (!wrap || !btn) return;
    var src = wrap.getAttribute('data-src');
    var loaded = false;
    function load() {
      if (loaded) return;
      loaded = true;
      var iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.title = 'Matterport 3D walkthrough of the Quincy townhome';
      iframe.className = 'absolute inset-0 h-full w-full';
      iframe.setAttribute('allow', 'xr-spatial-tracking; fullscreen');
      iframe.setAttribute('allowfullscreen', '');
      iframe.setAttribute('loading', 'lazy');
      wrap.innerHTML = '';
      wrap.appendChild(iframe);
    }
    btn.addEventListener('click', load);
    // Auto-load when scrolled into view (saves bandwidth on initial render)
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { if (e.isIntersecting) { load(); io.disconnect(); } });
      }, { rootMargin: '200px' });
      io.observe(wrap);
    }
  })();
</script>
