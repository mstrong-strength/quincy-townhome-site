---
import Base from '../layouts/Base.astro';
---
<Base>
  <main id="main" class="flex min-h-[70svh] items-center justify-center px-5">
    <div class="max-w-md text-center">
      <p class="font-display text-6xl font-semibold text-brand">404</p>
      <h1 class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink">Page not found</h1>
      <p class="mt-3 text-ink-soft">That page doesn't exist. Let's get you back to the Quincy Townhomes home.</p>
      <a href="/" class="mt-7 inline-block rounded-full bg-brand px-6 py-3 text-sm font-semibold text-ink">Back to home</a>
    </div>
  </main>
</Base>
