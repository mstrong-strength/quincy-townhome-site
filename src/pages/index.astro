---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WhatsSpecial from '../components/WhatsSpecial.astro';
import QuickFacts from '../components/QuickFacts.astro';
import Gallery from '../components/Gallery.astro';
import Tour from '../components/Tour.astro';
import Availability from '../components/Availability.astro';
import Pricing from '../components/Pricing.astro';
import Criteria from '../components/Criteria.astro';
import Floorplan from '../components/Floorplan.astro';
import Neighborhood from '../components/Neighborhood.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<Base>
  <Nav />
  <main id="main">
    <Hero />
    <QuickFacts />
    <WhatsSpecial />
    <Gallery />
    <Tour />
    <Availability />
    <Pricing />
    <Criteria />
    <Floorplan />
    <Neighborhood />
    <Contact />
  </main>
  <Footer />
</Base>
