---
import Base from '../layouts/Base.astro';
import { property } from '../data/property';
---
<Base>
  <main id="main" class="flex min-h-[70svh] items-center justify-center px-5">
    <div class="max-w-md text-center">
      <span class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-brand/15 text-brand-dark">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
      </span>
      <h1 class="mt-6 font-display text-3xl font-semibold tracking-tight text-ink">Thanks — we got it.</h1>
      <p class="mt-3 text-ink-soft">We'll be in touch shortly about {property.name}. In the meantime, you can apply or book a tour.</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a href={property.links.apply} target="_blank" rel="noopener" class="rounded-full bg-brand px-6 py-3 text-sm font-semibold text-ink">Apply Now</a>
        <a href="/" class="rounded-full border border-line px-6 py-3 text-sm font-semibold text-ink hover:border-brand">Back to home</a>
      </div>
    </div>
  </main>
</Base>
